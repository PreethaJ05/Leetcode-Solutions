class Solution {
    public int numOfSubarrays(int[] arr, int k, int threshold) {
        int cnt=0,sum=0;
        double avg=0;
        for(int i=0;i<k;i++) sum+=arr[i];
        avg=sum/k;
        if(avg>=threshold) cnt++;
        for(int i=1;i<arr.length-k+1;i++){
            sum=sum-arr[i-1]+arr[i+k-1];
            avg=sum/k;
            if(avg>=threshold) cnt++;
        }
        return cnt;
    }
}
